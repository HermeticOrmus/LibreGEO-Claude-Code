{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "{{SITE_URL}}#organization",
  "name": "{{ORG_NAME}}",
  "url": "{{SITE_URL}}",
  "logo": {
    "@type": "ImageObject",
    "url": "{{LOGO_URL}}",
    "width": {{LOGO_WIDTH}},
    "height": {{LOGO_HEIGHT}}
  },
  "description": "{{ORG_DESCRIPTION}}",
  "foundingDate": "{{FOUNDING_DATE}}",
  "sameAs": [
    "{{WIKIPEDIA_URL}}",
    "{{LINKEDIN_URL}}",
    "{{TWITTER_URL}}",
    "{{GITHUB_URL}}",
    "{{CRUNCHBASE_URL}}"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "{{CONTACT_TYPE}}",
    "email": "{{CONTACT_EMAIL}}"
  },
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "{{COUNTRY}}",
    "addressLocality": "{{LOCALITY}}"
  }
}
